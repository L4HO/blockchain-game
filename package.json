{
  "name": "blockchain-game-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Local Geth + smart contract test bed for a blockchain game arcade project.",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "geth:start": "powershell -ExecutionPolicy Bypass -File scripts/geth/start-dev-geth.ps1",
    "deploy:geth": "hardhat run scripts/deploy.ts --network gethLocal",
    "record:sample": "hardhat run scripts/record-sample.ts --network gethLocal",
    "verify:tx": "tsx scripts/verify-tx.ts",
    "clean:geth": "powershell -ExecutionPolicy Bypass -File scripts/geth/clean-dev-geth.ps1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.0",
    "@nomicfoundation/hardhat-toolbox": "^6.0.0",
    "@types/node": "^22.15.3",
    "dotenv": "^16.5.0",
    "ethers": "^6.14.1",
    "hardhat": "^2.24.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
